# Copier ce fichier en .env et remplir les valeurs avant de lancer la stack
# Ne jamais commiter le fichier .env — seul ce fichier .env.example est versionné

# Clé d'accès à l'API (choisir une valeur secrète)
API_KEY=

# URL de l'API vue par le dashboard (ne pas changer pour Docker Compose)
API_BASE_URL=http://api:8000
